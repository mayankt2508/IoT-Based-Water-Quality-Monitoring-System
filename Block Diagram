graph TD
    %% Define Node Colors
    classDef esp fill:#3b82f6,stroke:#1e3a8a,stroke-width:2px,color:#fff;
    classDef sensor fill:#10b981,stroke:#064e3b,stroke-width:2px,color:#fff;
    classDef display fill:#f59e0b,stroke:#78350f,stroke-width:2px,color:#fff;
    classDef cloud fill:#8b5cf6,stroke:#4c1d95,stroke-width:2px,color:#fff;

    %% Power Supply
    Pwr[🔋 Power Supply 5V] --> ESP

    %% Sensors
    subgraph SENSORS [Input Data Layer]
        S1[💧 pH Sensor Module]
        S2[🧂 Analog TDS Sensor]
        S3[🌫️ Optical Turbidity Sensor]
        S4[🌡️ DS18B20 Temp Sensor]
    end

    %% Microcontroller
    ESP(((🧠 ESP32 Microcontroller))):::esp

    %% Local Display
    subgraph LOCAL [Edge Processing]
        LCD[🖥️ 16x2 I2C LCD Display]:::display
    end

    %% Cloud Integration
    subgraph CLOUD [IoT Infrastructure]
        WIFI[📶 Wi-Fi Router]:::cloud
        BLYNK[☁️ Blynk IoT Server]:::cloud
        APP[📱 Mobile App & Alerts]:::cloud
    end

    %% Connections
    S1 -- Analog --> ESP
    S2 -- Analog --> ESP
    S3 -- Analog --> ESP
    S4 -- Digital 1-Wire --> ESP

    ESP -- I2C Protocol --> LCD
    ESP -. Wi-Fi Telemetry .-> WIFI
    WIFI --> BLYNK
    BLYNK -- Trigger Thresholds --> APP

    %% Apply Classes
    S1:::sensor; S2:::sensor; S3:::sensor; S4:::sensor;
